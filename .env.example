# Database Configuration
DB_HOST=localhost
DB_PORT=1521
DB_SID=XE
DB_USERNAME=project_tracker
DB_PASSWORD=your_password_here

# JWT Secret (at least 256 bits)
JWT_SECRET=your-secret-key-change-this-in-production-at-least-256-bits-long
JWT_EXPIRATION=86400000

# Application
APP_PORT=8080
APP_ENV=development

# Oracle JDBC Driver
ORACLE_JDBC_VERSION=ojdbc8
